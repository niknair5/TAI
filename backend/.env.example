# Copy to .env — required for local and Railway

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Settings → API → service_role (server only, never expose to browser)
SUPABASE_SERVICE_KEY=
# Settings → API → anon (public)
SUPABASE_ANON_KEY=

OPENAI_API_KEY=

# Comma-separated origins allowed to send cookies / Authorization to this API
CORS_ORIGINS=http://localhost:3000,https://ta-i.vercel.app

# Supabase Dashboard → Authentication → URL configuration:
# - Site URL: https://ta-i.vercel.app (and http://localhost:3000 for dev)
# - Redirect URLs: same + any preview URLs you use
